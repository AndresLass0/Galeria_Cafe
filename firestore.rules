rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own user document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        isAdmin()
      );
    }

    // Municipios: anyone can read, only admin can write
    match /municipios/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Productos: anyone can read, only admin can write
    match /productos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Subpersonas: owner can read/write their own, admin can read all
    match /subpersonas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Pedidos: owner can read/create, admin can read/update all
    match /pedidos/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    // Pedido Items: authenticated users can read/create, admin can update/delete
    match /pedidoItems/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Meta collection for seed status
    match /_meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }
  }
}
